    "        pp = mdl.predict_proba(Xs)[:, 1]\n",
    "        pc = mdl.predict(Xs)\n",
    "        rows.append({\n",
    "            'Split': name, 'Model': mdl_name,\n",
    "            'Accuracy': accuracy_score(ys, pc),\n",
