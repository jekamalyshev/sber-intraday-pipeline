    "            'Brier': brier_score_loss(ys, pp),\n",
    "        })\n",
    "\n",
    "metrics_df = pd.DataFrame(rows).pivot(index='Split', columns='Model')\n",
    "metrics_df = metrics_df.loc[['Train','Valid','Calib']]\n",
    "display(metrics_df.round(4))"
