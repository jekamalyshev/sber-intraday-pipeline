  {
   "cell_type": "markdown",
   "id": "md-cell7",
   "metadata": {},
   "source": [
    "## Cell 7 — Train / Valid / Calib Split"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-7",
   "metadata": {},
   "outputs": [],
   "source": [
    "X, y, leakage_cols = build_X_y_for_model(feature_df, n_in=5)\n",
    "print(f'X shape: {X.shape}')\n",
    "print(f'y shape: {y.shape}')\n",
    "print(f'y balance:\\n{y.value_counts(normalize=True).to_string()}')\n",
    "\n",
    "n = len(X)\n",
    "n_train = int(n * 0.60)\n",
    "n_valid = int(n * 0.20)\n",
    "\n",
    "X_train, y_train = X.iloc[:n_train], y.iloc[:n_train]\n",
    "X_valid, y_valid = X.iloc[n_train:n_train+n_valid], y.iloc[n_train:n_train+n_valid]\n",
    "X_calib, y_calib = X.iloc[n_train+n_valid:], y.iloc[n_train+n_valid:]\n",
    "\n",
    "print(f'\\nTrain: {len(X_train):,} | Valid: {len(X_valid):,} | Calib: {len(X_calib):,}')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "md-cell8",
   "metadata": {},
   "source": [
    "## Cell 8 — XGBoost Baseline Training & Evaluation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-8",
   "metadata": {},
   "outputs": [],
   "source": [
    "xgb_params = dict(\n",
    "    n_estimators=400,\n",
    "    max_depth=4,\n",
    "    learning_rate=0.05,\n",
    "    subsample=0.8,\n",
    "    colsample_bytree=0.8,\n",
    "    use_label_encoder=False,\n",
    "    eval_metric='logloss',\n",
    "    random_state=42,\n",
    ")\n",
    "\n",
    "xgb_model = XGBClassifier(**xgb_params)\n",
    "xgb_model.fit(X_train, y_train, eval_set=[(X_valid, y_valid)], verbose=False)\n",
    "print('XGBoost trained ✓')\n",
    "\n",
    "def evaluate_model(model, X, y, split_name):\n",
    "    pred_class = model.predict(X)\n",
    "    pred_prob = model.predict_proba(X)[:, 1]\n",
    "    acc = accuracy_score(y, pred_class)\n",
    "    auc = roc_auc_score(y, pred_prob)\n",
    "    ll = log_loss(y, pred_prob)\n",
    "    bs = brier_score_loss(y, pred_prob)\n",
    "    print(f'{split_name:8s} | Acc={acc:.4f}  AUC={auc:.4f}  LogLoss={ll:.4f}  Brier={bs:.4f}')\n",
    "    return acc, auc, ll, bs\n",
    "\n",
    "print('\\n--- XGBoost Baseline ---')\n",
    "r_train = evaluate_model(xgb_model, X_train, y_train, 'Train')\n",
    "r_valid = evaluate_model(xgb_model, X_valid, y_valid, 'Valid')\n",
    "r_calib_xgb = evaluate_model(xgb_model, X_calib, y_calib, 'Calib')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "md-cell9",
   "metadata": {},
   "source": [
    "## Cell 9 — Probability Calibration (Platt Scaling)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-9",
   "metadata": {},
   "outputs": [],
   "source": [
    "cal_kwargs = {_CALIB_ESTIMATOR_KWARG: xgb_model}\n",
    "calibrated_model = CalibratedClassifierCV(**cal_kwargs, method='sigmoid', cv='prefit')\n",
    "calibrated_model.fit(X_calib, y_calib)\n",
    "print('Calibration fitted ✓')\n",
    "\n",
    "prob_true_pre, prob_pred_pre = calibration_curve(y_valid, xgb_model.predict_proba(X_valid)[:, 1], n_bins=10)\n",
    "prob_true_cal, prob_pred_cal = calibration_curve(y_valid, calibrated_model.predict_proba(X_valid)[:, 1], n_bins=10)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(7, 6))\n",
    "ax.plot([0,1],[0,1],'k--', label='Perfect calibration')\n",
    "ax.plot(prob_pred_pre, prob_true_pre, 'o-', label='XGBoost (raw)', color='steelblue')\n",
    "ax.plot(prob_pred_cal, prob_true_cal, 's-', label='Calibrated (Platt)', color='tomato')\n",
    "ax.set_xlabel('Mean predicted probability')\n",
    "ax.set_ylabel('Fraction of positives')\n",
    "ax.set_title('Calibration Curve — Valid split')\n",
    "ax.legend()\n",
    "plt.tight_layout()\n",
    "plt.show()"
